#!/bin/bash
# Verifier skill for Founder Bottleneck Diagnostic landing page
# Captures screenshots and validates page structure

set -e

URL="http://localhost:3000/founder-diagnostic"
SCREENSHOT_DIR="/tmp/founder-diagnostic-screenshots"
mkdir -p "$SCREENSHOT_DIR"

echo "🔍 Verifying Founder Bottleneck Diagnostic landing page..."
echo ""

# Ensure dev server is running
if ! curl -s "$URL" > /dev/null 2>&1; then
  echo "❌ Dev server not running at $URL"
  echo "Start it with: pnpm dev"
  exit 1
fi

echo "✅ Server is running"
echo ""

# Fetch and validate page structure
echo "📋 Validating page sections..."
PAGE_HTML=$(curl -s "$URL")

# Check for all 6 sections
SECTIONS=(
  "Something in your startup is slowing everything down"
  "Your team is moving but nothing is landing"
  "Most founders who've done this say"
  "One session. 90 minutes. You leave with"
  "I've worked with 25+ early-stage founders"
  "DM me \"diagnostic\" on LinkedIn"
)

for section in "${SECTIONS[@]}"; do
  if echo "$PAGE_HTML" | grep -q "$section"; then
    echo "  ✅ Found: $section"
  else
    echo "  ❌ Missing: $section"
  fi
done

echo ""
echo "🎬 Testimonials check..."
if echo "$PAGE_HTML" | grep -q "Founder, B2B SaaS"; then
  echo "  ✅ William testimony (anonymous)"
fi
if echo "$PAGE_HTML" | grep -q "Hien Nguyen, Sidekiq"; then
  echo "  ✅ Hien Nguyen testimony"
fi
if echo "$PAGE_HTML" | grep -q "drive.google.com"; then
  echo "  ✅ Video testimonial embed"
fi

echo ""
echo "💡 Positioning check..."
if echo "$PAGE_HTML" | grep -q "I'm not offering coaching or advisory through this page"; then
  echo "  ✅ Advisory positioning clarified"
fi

echo ""
echo "🔗 CTA check..."
if echo "$PAGE_HTML" | grep -q "https://www.linkedin.com/in/trungfromberlin/"; then
  echo "  ✅ LinkedIn profile link present"
fi
if echo "$PAGE_HTML" | grep -q "\$299"; then
  echo "  ✅ Pricing displayed"
fi

echo ""
echo "✨ Verification complete!"
echo ""
echo "For visual inspection, open:"
echo "  http://localhost:3000/founder-diagnostic"
